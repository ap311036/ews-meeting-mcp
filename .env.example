EWS_ENDPOINT=https://mail.company.com/EWS/Exchange.asmx
EWS_EMAIL=your_user@company.com
EWS_USERNAME='DOMAIN\your_user'
EWS_PASSWORD='change-me'
# macOS Keychain fallback when EWS_PASSWORD is omitted:
# EWS_PASSWORD_KEYCHAIN_SERVICE=ews-meeting-mcp
# EWS_PASSWORD_KEYCHAIN_ACCOUNT='DOMAIN\your_user'
EWS_AUTH_TYPE=NTLM
EWS_TIMEZONE=Asia/Taipei
# Optional local scheduling policy. Defaults to ./ews-meeting-policy.json when present.
# EWS_MEETING_POLICY_FILE=/absolute/path/to/ews-meeting-policy.json
